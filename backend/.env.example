# Text-to-SQL Evaluation Platform
# Copy this file to backend/.env and fill your own values.

# App settings
APP_NAME=Text-to-SQL Evaluation Platform
APP_VERSION=1.0.0
DEBUG=false

# Database
DATABASE_URL=sqlite+aiosqlite:///./text2sql.db

# Sandbox
QUERY_TIMEOUT_SECONDS=5
MAX_RESULT_ROWS=100
RATE_LIMIT_QPS=10

# Judge LLM (optional, for failed-case diagnosis)
# API key is NOT stored in .env anymore.
# Use UI "裁判模型配置" to save key into backend/.secrets/judge_api_key (local-only).
JUDGE_LLM_ENDPOINT=
JUDGE_LLM_DEFAULT_MODEL=gpt-4o-mini
