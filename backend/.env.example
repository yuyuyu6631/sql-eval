# Text-to-SQL Evaluation Platform - Environment Variables

# App Settings
APP_NAME="Text-to-SQL Evaluation Platform"
APP_VERSION="1.0.0"

# Database
DATABASE_URL=sqlite+aiosqlite:///./text2sql.db

# Sandbox Settings
QUERY_TIMEOUT_SECONDS=5
MAX_RESULT_ROWS=100
RATE_LIMIT_QPS=10

# LLM Settings (Optional - for AI diagnosis)
# JUDGE_LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
# JUDGE_LLM_API_KEY=your-api-key-here
